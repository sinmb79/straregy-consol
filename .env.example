# ============================================================
# 22B Strategy Engine - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Binance API ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true          # set to false for live trading
# Testnet mode uses:
#   REST: https://testnet.binancefuture.com
#   WS:   wss://stream.binancefuture.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change_me_to_a_random_secret

# --- Database ---
DB_PATH=./data/trading.db

# --- System ---
# ACTIVE | LIMITED | OBSERVE | BLOCKED
SYSTEM_MODE=OBSERVE
LOG_LEVEL=INFO

# --- Tracked symbols (comma-separated) ---
TRACKED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT

# --- Offline validation dataset mode ---
# Safe read-only import path for offline/backtest/paper validation datasets.
# When enabled, the engine loads staged candles into SQLite/DataStore,
# forces OBSERVE if SYSTEM_MODE=ACTIVE, and skips live collector/executor startup.
VALIDATION_DATASET_ENABLED=false
VALIDATION_DATASET_ROOT=./data/import_staging/validation_datasets
# Optional offline replay: preload warmup bars, then feed remaining candles one bar at a time.
VALIDATION_REPLAY_ENABLED=false
VALIDATION_REPLAY_WARMUP_BARS=52
VALIDATION_REPLAY_STEP_DELAY_MS=0
VALIDATION_REPLAY_MAX_STEPS=0

# Optional staged replay: warm up historical bars, then feed remaining candles
# bar-by-bar into offline regime detection + paper strategy logic only.
VALIDATION_REPLAY_ENABLED=false
VALIDATION_REPLAY_WARMUP_BARS=52
VALIDATION_REPLAY_STEP_DELAY_MS=0
VALIDATION_REPLAY_MAX_STEPS=0

# --- Data collection intervals ---
CANDLE_INTERVALS=1h,4h
TICKER_UPDATE_INTERVAL_SEC=5
CANDLE_LIMIT=200              # number of historical candles to fetch on start

# --- OpenClaw AI (Phase 4) ---
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_AGENT_ID=main
# Set to false to disable all AI analysis (still collects metrics)
AI_ENABLED=true

# --- Review schedule ---
# Day of week for weekly review: 0=Monday, 6=Sunday (default 6 = Sunday)
WEEKLY_REVIEW_DAY=6
# Hour (UTC) for weekly review run (default 0 = 00:00 UTC Sunday)
WEEKLY_REVIEW_HOUR=0
# Hour (UTC) for daily review run (default 22 = 22:00 UTC)
DAILY_REVIEW_HOUR=22
