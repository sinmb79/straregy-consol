# ============================================================
# 22B Strategy Engine — .gitignore
# ============================================================

# ─── Claude Code local settings ─────────────────────────────
.claude/

# ─── Secrets / Credentials — NEVER commit ───────────────────
.env
.env.*
*.env
secrets.json
credentials.json
*.pem
*.key

# ─── Internal planning / design documents ───────────────────
# (*.txt 내부 기획문서 — 코드가 아님)
*.txt
!requirements*.txt

# ─── Database / runtime data ────────────────────────────────
# 실거래 데이터, 백테스트 DB, 런타임 파라미터 포함 — 코드 아님
/data/
*.db
*.sqlite
*.sqlite3

# ─── Python cache ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual environments ────────────────────────────────────
venv/
.venv/
env/
.env_backup

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/

# ─── Binary / large files ───────────────────────────────────
cloudflared.exe
*.exe
*.dll
*.so
*.dylib

# ─── OS / editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.suo
*.user

# ─── Windows scripts (personal / machine-specific) ──────────
start_silent.vbs

# ─── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
